---
import BaseLayout from '../layouts/BaseLayout.astro';
import Breadcrumbs from '../components/Breadcrumbs.astro';
import Illustration from '../components/Illustration.astro';
import LoanPayoffCalculator from '../components/LoanPayoffCalculator.astro';
import RelatedTools from '../components/RelatedTools.astro';
import { calcSchema } from '../lib/seo';
import HowItWorks from '../components/HowItWorks.astro';

const title = 'Loan Payoff Calculator — Time & Interest Saved with Extra Payments | Payoff Logic';
const description =
  'Free loan payoff calculator: see exactly how many months earlier you become debt-free and how much interest you save by paying extra each month. Works for any fixed-rate loan.';

const faqs = [
  {
    q: 'How do extra payments shorten a loan?',
    a: 'Every extra dollar goes directly to principal. Because interest is charged each month on the remaining balance, a smaller balance means less interest next month, so more of your regular payment also hits principal. The effect compounds every month, which is why even $50–$100 extra removes months or years from the schedule.',
  },
  {
    q: 'How long will it take to pay off my loan?',
    a: 'With a fixed rate and fixed payment, the payoff time follows directly from the amortization formula. For example, a $20,000 loan at 6.5% APR with a $400 payment takes about 58 months. Enter your own balance, rate, and payment above for the exact month — and a calendar payoff date.',
  },
  {
    q: 'Is it better to pay extra monthly or make one big lump-sum payment?',
    a: 'Dollar for dollar, sooner beats later: money applied to principal today stops accruing interest immediately. A lump sum now saves more than the same total spread over the year. In practice, a consistent monthly extra is easier to stick to — and consistency usually wins.',
  },
  {
    q: 'Should I include taxes, insurance, or escrow in the monthly payment field?',
    a: 'No. Enter only the principal-and-interest portion. Escrow items (property tax, insurance) don’t reduce your balance, so including them would make the payoff look faster than it really is.',
  },
  {
    q: 'Does this work for car loans, personal loans, and student loans?',
    a: 'Yes — any fixed-rate, monthly-payment loan amortizes the same way. For credit cards, which have variable minimum payments, use our debt snowball calculator instead; it models minimums and rollover payments across multiple cards.',
  },
  {
    q: 'Will paying extra lower my monthly payment?',
    a: 'Usually not. On most installment loans, extra principal shortens the loan’s life but the required payment stays the same (unless you request a re-amortization, called recasting, which some mortgage lenders offer for a fee). The win is the payoff date and the interest, not the monthly bill.',
  },
  {
    q: 'Are there prepayment penalties?',
    a: 'Most modern U.S. consumer loans have none, but some personal and auto loans (and a few mortgages) do. Check your note or ask your lender. Also confirm that extra amounts are applied to principal — not treated as an early next-month payment.',
  },
  {
    q: 'How accurate is this calculator?',
    a: 'The amortization math is exact and verified against published reference values and closed-form formulas (our test cases are documented publicly in the site repository). Your real-world results can differ slightly due to daily-interest accrual methods, payment dates, and rounding your lender uses.',
  },
];

const schema = calcSchema({
  name: 'Payoff Logic Loan Payoff Calculator',
  path: '/loan-payoff-calculator/',
  description,
  crumbName: 'Loan Payoff Calculator',
  faqs,
});
---

<BaseLayout title={title} description={description} schema={schema}>
  <Breadcrumbs crumbs={[{ label: 'Loan Payoff Calculator' }]} />

  <div class="mx-auto max-w-5xl px-4 pb-4 sm:px-6">
    <header class="flex items-start justify-between gap-6 py-5">
      <div class="min-w-0">
      <h1 class="text-2xl font-bold text-navy-900 sm:text-3xl">Loan Payoff Calculator</h1>
      <p class="mt-2 max-w-3xl text-sm leading-relaxed text-navy-700 sm:text-base">
        Find your exact debt-free date — and see how much time and interest an extra
        monthly payment saves. Works for auto, personal, student, and any other
        fixed-rate loan. Free, no signup, nothing you enter leaves your browser.
      </p>
    </div>
      <Illustration kind="payoff" class="hidden w-40 shrink-0 sm:block" />
    </header>

    <!-- AD_SLOT: loan-payoff, above-fold right (desktop sidebar) -->

    <LoanPayoffCalculator />

    <!-- AD_SLOT: loan-payoff, below results -->

    <article class="mx-auto mt-12 max-w-3xl space-y-6 text-base leading-relaxed text-navy-700">
      <section>
        <h2 class="text-xl font-bold text-navy-900">Why small extra payments have outsized results</h2>
        <p class="mt-3">
          A loan payment is split between interest (the lender's charge on your current
          balance) and principal (what actually reduces the debt). Early in a loan the
          interest share is at its largest, because the balance is at its largest. An
          extra payment skips the queue: 100% of it hits principal. That shrinks every
          future month's interest charge, which lets more of every future regular
          payment hit principal too — a compounding chain in your favor.
        </p>
        <p class="mt-3">
          Concrete example from the math above: on a $20,000 loan at 6.5% with a $400
          payment, adding $100/month makes you debt-free about 13 months sooner and
          saves roughly $700 of interest. The higher your rate, the more dramatic this
          gets — at credit-card rates, extra payments are the highest-return "investment"
          most people have available.
        </p>
      </section>

      <section>
        <h2 class="text-xl font-bold text-navy-900">Three things to check before paying extra</h2>
        <ul class="mt-3 list-disc space-y-2 pl-6">
          <li><strong>Application of funds.</strong> Tell your lender extras go to <em>principal</em>. Some servicers otherwise hold them as a prepaid next installment, which saves you nothing.</li>
          <li><strong>Prepayment penalties.</strong> Rare on modern loans, but check the note — especially on personal loans and some auto loans.</li>
          <li><strong>Higher-priority money.</strong> If you carry credit-card debt at 20%+ or lack an emergency fund, those usually come first. Our <a href="/debt-snowball-calculator/" class="font-medium text-navy-900 underline hover:text-navy-600">debt snowball calculator</a> sequences multiple debts properly.</li>
        </ul>
      </section>

      <HowItWorks formulas={[{"label":"Months to payoff","math":"n = −ln(1 − r·P ÷ M) ÷ ln(1 + r)"},{"label":"Monthly interest","math":"interest this month = balance × r"}]} vars={[{"sym":"P","desc":"current balance"},{"sym":"r","desc":"monthly rate — APR ÷ 12, as a decimal"},{"sym":"M","desc":"your fixed monthly payment"},{"sym":"n","desc":"months until the balance hits zero"}]}>
        <p class="mt-3">Enter a balance, rate, and monthly payment, and the payoff month follows directly from the amortization identity — the same relationship every lender&rsquo;s schedule obeys:</p>
        <p class="mt-3" slot="after">If M is not larger than the first month&rsquo;s interest (balance × r), the balance can never fall — the calculator flags that plainly instead of showing a misleading date. Extra payments go straight to principal in the schedule, and the totals are verified in our automated tests against this closed-form formula.</p>
      </HowItWorks>

      <section>
        <h2 class="text-xl font-bold text-navy-900">Frequently asked questions</h2>
        <div class="mt-4 space-y-5">
          {faqs.map((f) => (
            <div>
              <h3 class="font-semibold text-navy-900">{f.q}</h3>
              <p class="mt-1">{f.a}</p>
            </div>
          ))}
        </div>
      </section>

      <RelatedTools currentSlug="loan-payoff-calculator" />

      <p class="rounded-lg bg-navy-50 p-4 text-sm">
        <strong>Disclaimer:</strong> Educational purposes only — not financial advice.
        Verify figures with your lender. See our
        <a href="/terms/" class="underline hover:text-navy-900">Terms of Use</a>.
      </p>
    </article>
  </div>
</BaseLayout>
