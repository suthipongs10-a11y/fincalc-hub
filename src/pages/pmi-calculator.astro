---
import BaseLayout from '../layouts/BaseLayout.astro';
import Breadcrumbs from '../components/Breadcrumbs.astro';
import Illustration from '../components/Illustration.astro';
import PmiCalculator from '../components/PmiCalculator.astro';
import RelatedTools from '../components/RelatedTools.astro';
import { calcSchema } from '../lib/seo';
import HowItWorks from '../components/HowItWorks.astro';
import WorkedExample from '../components/WorkedExample.astro';

const title = 'PMI Calculator — Monthly Cost & Exact Removal Date | Payoff Logic';
const description =
  'Free PMI calculator: your monthly PMI, the exact month it auto-cancels at 78% LTV under federal law, total PMI paid — and how much sooner extra payments remove it.';

const faqs = [
  { q: 'How much is PMI per month?', a: 'PMI rates run roughly 0.3%–1.5% of the loan per year depending on credit score and down payment; 0.5% is a fair mid-range default. On a $360,000 loan that’s $150/month. Enter your quoted rate above for your number.' },
  { q: 'When does PMI go away?', a: 'Automatically when your balance is scheduled to reach 78% of the home’s original value (Homeowners Protection Act), assuming you’re current. You can request cancellation earlier at 80%. The calculator shows your exact month for both thresholds.' },
  { q: 'Can I remove PMI early without refinancing?', a: 'Yes, two ways: extra principal payments (pull the 78% date forward — model it above) or a new appraisal after appreciation/improvements, if your loan-to-current-value has fallen enough (rules vary by loan age and investor). Refinancing is the third path.' },
  { q: 'Is PMI tax deductible?', a: 'The PMI deduction has lapsed and been revived multiple times in tax law; as of the 2026 filing landscape it is not a reliable planning assumption. Check current-year IRS guidance or a tax professional.' },
  { q: 'Is PMI the same as FHA mortgage insurance?', a: 'No. PMI is on conventional loans and cancels; FHA MIP has an upfront 1.75% premium plus annual charges that usually last the life of the loan at low down payments. Compare programs in our FHA calculator.' },
  { q: 'Should I avoid PMI at all costs?', a: 'No — PMI is the price of buying years earlier than a 20% down payment allows. In appreciating markets, waiting can cost more than PMI does. Run the totals and decide with numbers, not slogans.' },
];

const schema = calcSchema({
  name: 'Payoff Logic PMI Calculator',
  path: '/pmi-calculator/',
  description,
  crumbName: 'PMI Calculator',
  faqs,
});
---

<BaseLayout title={title} description={description} schema={schema}>
  <Breadcrumbs crumbs={[{ label: 'PMI Calculator' }]} />
  <div class="mx-auto max-w-5xl px-4 pb-4 sm:px-6">
    <header class="flex items-start justify-between gap-6 py-5">
      <div class="min-w-0">
        <h1 class="text-2xl font-bold text-navy-900 sm:text-3xl">PMI Calculator</h1>
        <p class="mt-2 max-w-3xl text-sm leading-relaxed text-navy-700 sm:text-base">
          What PMI costs you monthly, the exact month it cancels under the federal 78%
          rule, the total you'll pay — and how extra payments shrink all three. Free,
          no signup.
        </p>
      </div>
      <Illustration kind="shield" class="hidden w-40 shrink-0 sm:block" />
    </header>

    <!-- AD_SLOT: pmi, above-fold right (desktop sidebar) -->
    <PmiCalculator />
    <!-- AD_SLOT: pmi, below results -->

    <article class="mx-auto mt-12 max-w-3xl space-y-6 text-base leading-relaxed text-navy-700">
      <section>
        <h2 class="text-xl font-bold text-navy-900">The three exits, ranked by effort</h2>
        <p class="mt-3">
          <strong>Wait</strong> for the automatic 78% date (zero effort, slowest).
          <strong>Request at 80%</strong> — a written request with good payment history,
          typically months earlier. <strong>Force it</strong> with extra principal or a
          reappraisal after appreciation — often years earlier in rising markets. The
          deep mechanics and edge cases are in our
          <a href="/guides/pmi-explained/" class="font-medium text-navy-900 underline hover:text-navy-600">PMI guide</a>;
          the full payment picture (taxes and insurance included) is in the
          <a href="/mortgage-calculator/" class="font-medium text-navy-900 underline hover:text-navy-600">mortgage calculator</a>.
        </p>
      </section>
      <HowItWorks formulas={[{"label":"Monthly PMI","math":"PMI = loan amount × annual PMI rate ÷ 12"},{"label":"Auto-cancel month","math":"first month the scheduled balance reaches 78% of the original home value"}]} vars={[]}>
        <p class="mt-3">Monthly PMI is straightforward; the valuable output is the exact cancellation month, which requires the full schedule:</p>
        <p class="mt-3" slot="after">The 78% automatic date and the 80% request date (Homeowners Protection Act) come from walking the amortization schedule. Add extra payments and the engine re-amortizes to show how much sooner both dates arrive.</p>
      </HowItWorks>

      <WorkedExample setup="A $400,000 home with $30,000 down (7.5%), a $370,000 loan at 6.5% over 30 years, with PMI at 0.5%/year." rows={[{"label":"Loan-to-value at start","value":"92.5%"},{"label":"Monthly PMI","value":"$154.17"},{"label":"PMI auto-cancels at payment","value":"124 (about year 11)","strong":true},{"label":"Total PMI paid if you wait","value":"$18,962"}]}>
        <p class="mt-3">PMI costs <strong>$154 a month</strong> here and, left alone, auto-cancels around <strong>payment 124</strong> when the balance reaches 78% of the original value — after nearly $19,000 paid. You can request cancellation earlier at 80% LTV, or force it years sooner with extra principal or a new appraisal after appreciation. PMI is not money wasted, though: it is the price of buying without a full 20%, which in a rising market can beat waiting. See <a href="/guides/pmi-explained/" class="font-medium text-navy-900 underline hover:text-navy-600">PMI explained</a>.</p>
      </WorkedExample>


      <section>
        <h2 class="text-xl font-bold text-navy-900">Frequently asked questions</h2>
        <div class="mt-4 space-y-5">
          {faqs.map((f) => (<div><h3 class="font-semibold text-navy-900">{f.q}</h3><p class="mt-1">{f.a}</p></div>))}
        </div>
      </section>
      <RelatedTools currentSlug="pmi-calculator" slugs={['mortgage-calculator', 'down-payment-calculator', 'extra-payment-mortgage-calculator', 'fha-loan-calculator']} />
      <p class="rounded-lg bg-navy-50 p-4 text-sm"><strong>Disclaimer:</strong> Educational purposes only — not financial advice. Servicer rules and investor overlays vary. See our <a href="/terms/" class="underline hover:text-navy-900">Terms of Use</a>.</p>
    </article>
  </div>
</BaseLayout>
