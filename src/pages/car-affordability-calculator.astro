---
import BaseLayout from '../layouts/BaseLayout.astro';
import Breadcrumbs from '../components/Breadcrumbs.astro';
import Illustration from '../components/Illustration.astro';
import CarAffordabilityCalculator from '../components/CarAffordabilityCalculator.astro';
import RelatedTools from '../components/RelatedTools.astro';
import { calcSchema } from '../lib/seo';

const title = 'How Much Car Can I Afford? — Car Affordability Calculator | Payoff Logic';
const description =
  'Free car affordability calculator: turn a monthly budget into a maximum sticker price — tax-aware, with down payment and trade-in — plus the 20/4/10 rule sanity check.';

const faqs = [
  { q: 'How much car can I afford on my salary?', a: 'The 20/4/10 guideline: 20% down, finance no more than 4 years, and keep TOTAL car costs (payment + insurance + fuel) under 10% of gross monthly income. On an $80,000 salary that’s roughly $660/month all-in — meaning a loan payment nearer $400–450. Enter your payment budget above and the calculator converts it to a sticker price.' },
  { q: 'How does the calculator turn a budget into a price?', a: 'It inverts the loan math: your budget defines the maximum loan at your APR and term; then it adds your down payment and trade-in and backs out sales tax (respecting whether your state taxes the price before or after trade-in credit) to find the price whose payment exactly equals your budget.' },
  { q: 'Why does the max price drop if I roll tax into the loan?', a: 'Financed tax consumes loan capacity: every borrowed tax dollar is a dollar of car you can’t finance. We assume tax paid upfront for the max-price math; the full auto loan calculator models both ways.' },
  { q: 'Should I count insurance in the budget?', a: 'Yes — outside the loan. Insurance runs $100–$250+/month depending on driver and vehicle, and sporty or new models cost more to insure. A $450 loan budget with $180 insurance is really a $630/month decision; the 10% rule is about the total.' },
  { q: 'New or used for a tight budget?', a: 'Used generally wins on price and depreciation, but carries higher APRs (typically +1–3 points) and maintenance risk. Try the calculator both ways: same budget, used APR vs new APR — the price gap narrows more than people expect, but rarely closes.' },
  { q: 'How much should I put down on a car?', a: '20% on new (roughly matching first-year depreciation, keeping you above water) and ~10% on used is the classic guidance. Less down is common but raises the odds of owing more than the car’s worth — the negative-equity trap covered in our car loan guide.' },
];

const schema = calcSchema({
  name: 'Payoff Logic Car Affordability Calculator',
  path: '/car-affordability-calculator/',
  description,
  crumbName: 'Car Affordability Calculator',
  faqs,
});
---

<BaseLayout title={title} description={description} schema={schema}>
  <Breadcrumbs crumbs={[{ label: 'Car Affordability Calculator' }]} />
  <div class="mx-auto max-w-5xl px-4 pb-4 sm:px-6">
    <header class="flex items-start justify-between gap-6 py-5">
      <div class="min-w-0">
        <h1 class="text-2xl font-bold text-navy-900 sm:text-3xl">How Much Car Can I Afford?</h1>
        <p class="mt-2 max-w-3xl text-sm leading-relaxed text-navy-700 sm:text-base">
          Start from the monthly number you can sustain — the calculator converts it
          into a maximum sticker price, tax-aware, with your down payment and trade-in
          counted. Free, no signup.
        </p>
      </div>
      <Illustration kind="car" class="hidden w-40 shrink-0 sm:block" />
    </header>

    <!-- AD_SLOT: car-affordability, above-fold right (desktop sidebar) -->
    <CarAffordabilityCalculator />
    <!-- AD_SLOT: car-affordability, below results -->

    <article class="mx-auto mt-12 max-w-3xl space-y-6 text-base leading-relaxed text-navy-700">
      <section>
        <h2 class="text-xl font-bold text-navy-900">Budget-first beats payment-first</h2>
        <p class="mt-3">
          Dealers sell payments, and any payment can be manufactured with a long
          enough term — that's how buyers end up in 84-month loans on depreciating
          assets. Working budget-first with a sane term (48–60 months) fixes the
          decision before the showroom: you know your ceiling, and the sensitivity
          table shows exactly what another $100/month buys. When you've picked a
          target car, price the full deal — trade-in payoff, state tax rules, fees —
          in the <a href="/auto-loan-calculator/" class="font-medium text-navy-900 underline hover:text-navy-600">auto loan calculator</a>,
          and read <a href="/guides/how-car-loan-interest-works/" class="font-medium text-navy-900 underline hover:text-navy-600">how car loan interest works</a>
          for the term-length math.
        </p>
      </section>
      <section>
        <h2 class="text-xl font-bold text-navy-900">Frequently asked questions</h2>
        <div class="mt-4 space-y-5">
          {faqs.map((f) => (<div><h3 class="font-semibold text-navy-900">{f.q}</h3><p class="mt-1">{f.a}</p></div>))}
        </div>
      </section>
      <RelatedTools currentSlug="car-affordability-calculator" slugs={['auto-loan-calculator', 'auto-refinance-calculator', 'loan-payoff-calculator', 'house-affordability-calculator']} />
      <p class="rounded-lg bg-navy-50 p-4 text-sm"><strong>Disclaimer:</strong> Educational purposes only — not financial advice. Insurance, fuel, and maintenance are outside the loan math — budget them separately. See our <a href="/terms/" class="underline hover:text-navy-900">Terms of Use</a>.</p>
    </article>
  </div>
</BaseLayout>
