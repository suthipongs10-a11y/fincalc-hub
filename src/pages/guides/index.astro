---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import Illustration from '../../components/Illustration.astro';
import { SITE } from '../../config';

const guides = [
  { slug: 'how-amortization-works', title: 'How Amortization Works', desc: 'Why early payments are mostly interest, when you truly own half the house, and how to read a schedule.', cluster: 'Mortgage' },
  { slug: 'pmi-explained', title: 'PMI Explained: Cost, Rules, Removal', desc: 'What PMI costs, the federal 80/78% cancellation rules, and three ways to kill it early.', cluster: 'Mortgage' },
  { slug: 'how-extra-payments-work', title: 'How Extra Mortgage Payments Really Work', desc: 'What $100, $200, or $500 extra actually buys — and the three mistakes that cancel the benefit.', cluster: 'Mortgage' },
  { slug: 'income-needed-for-a-house', title: 'Income Needed for a $250k–$1M House', desc: 'Real income tables under the 28% rule, with every assumption shown and adjustable.', cluster: 'Mortgage' },
  { slug: '15-vs-30-year-mortgage', title: '15 vs. 30-Year Mortgage: The Real Math', desc: 'Payments, lifetime interest, 5-year equity — plus the "30 paid like a 15" third option, priced.', cluster: 'Mortgage' },
  { slug: 'property-taxes-escrow-explained', title: 'Property Taxes & Escrow, Explained', desc: 'Why payments rise after year one, escrow shortage letters, and the exemptions buyers forget to file.', cluster: 'Mortgage' },
  { slug: 'homeowners-insurance-in-your-payment', title: 'Homeowners Insurance in Your Payment', desc: 'What drives premiums (state, roof, deductible), the year-two jump, and cutting cost without gutting coverage.', cluster: 'Mortgage' },
  { slug: 'fha-mip-vs-conventional-pmi', title: 'FHA MIP vs. Conventional PMI', desc: 'A worked $350k comparison: who wins by credit tier, and why insurance duration beats rate.', cluster: 'Mortgage' },
  { slug: 'va-funding-fee-explained', title: 'The VA Funding Fee, Explained', desc: 'Every tier, the exemptions, and the finance-vs-upfront math on a real example.', cluster: 'Mortgage' },
  { slug: 'how-much-down-payment', title: 'How Much Down Payment Do You Really Need?', desc: 'Program minimums 0–20%, what each tier costs monthly, and when smaller is smarter.', cluster: 'Mortgage' },
  { slug: 'mortgage-points-worth-it', title: 'Mortgage Points: When They’re Worth It', desc: 'The break-even bet on loan longevity — and the refinance risk that kills points.', cluster: 'Mortgage' },
  { slug: 'first-time-homebuyer-costs', title: 'First-Time Homebuyer Costs Checklist', desc: 'Every cost beyond the down payment, itemized — closing, prepaids, move-in, and the cushion.', cluster: 'Mortgage' },
  { slug: 'hoa-fees-explained', title: 'HOA Fees and Your Mortgage Budget', desc: 'The payment that never amortizes: DTI impact, special assessments, and six due-diligence questions.', cluster: 'Mortgage' },
  { slug: 'credit-score-for-a-mortgage', title: 'Credit Score Needed by Loan Type', desc: 'Minimums for each program — and the 0.5–0.75% rate cost of score tiers, in dollars.', cluster: 'Mortgage' },
  { slug: 'closing-costs-explained', title: 'Closing Costs: What’s in Them', desc: 'The four buckets on your Loan Estimate, which lines are shoppable, and how state rules differ.', cluster: 'Mortgage' },
  { slug: 'snowball-vs-avalanche', title: 'Snowball vs. Avalanche: The Real Math', desc: 'A worked example where the methods truly differ, and an honest rule for choosing.', cluster: 'Debt' },
  { slug: 'how-credit-card-interest-works', title: 'How Credit Card Interest Is Calculated', desc: 'Daily compounding, the grace-period cliff, and what fixed payments do to the timeline.', cluster: 'Debt' },
  { slug: 'minimum-payments-trap', title: 'Why Minimum Payments Keep You in Debt', desc: 'The declining-minimum design, and the one mechanical change that collapses it.', cluster: 'Debt' },
  { slug: 'pay-off-10k-credit-card', title: 'How to Pay Off $10k of Card Debt', desc: 'Four realistic plans priced in months and interest — brute force, transfer, loan, hybrid.', cluster: 'Debt' },
  { slug: 'debt-consolidation-when-it-helps', title: 'Consolidation: When It Helps vs. Hurts', desc: 'Three tests that separate real rate cuts from repackaged trouble — and the refill trap.', cluster: 'Debt' },
  { slug: 'simple-vs-amortized-interest', title: 'Simple vs. Amortized vs. Compound Interest', desc: 'The three machines behind every debt, and how the label changes what extra payments are worth.', cluster: 'Debt' },
  { slug: 'snowflaking-micro-payments', title: 'Snowflaking: Micro-Payments That Work', desc: 'How $5–$25 windfalls, sent same-day, take a year off a card — with the math.', cluster: 'Debt' },
  { slug: 'debt-to-income-ratio-explained', title: 'Debt-to-Income Ratio, Explained', desc: 'Front-end vs back-end, real approval limits by program, and the fastest DTI fixes.', cluster: 'Debt' },
  { slug: 'when-to-refinance', title: 'When Refinancing Is Worth It', desc: 'Break-even months, the term-reset trap, no-closing-cost decoded — with worked numbers.', cluster: 'Refinance' },
  { slug: 'refinance-closing-costs', title: 'Refinance Closing Costs Breakdown', desc: 'Line by line — including the title reissue rate most borrowers never claim.', cluster: 'Refinance' },
  { slug: 'cash-out-vs-heloc', title: 'Cash-Out vs. HELOC vs. Home Equity Loan', desc: 'Three doors into your equity, matched to the job — and the one question that decides.', cluster: 'Refinance' },
  { slug: 'streamline-refinance', title: 'Streamline Refis (FHA & VA IRRRL)', desc: 'No appraisal, minimal docs, 0.5% VA fee — the shortcut existing FHA/VA borrowers miss.', cluster: 'Refinance' },
  { slug: 'does-refinancing-hurt-credit', title: 'Does Refinancing Hurt Your Credit?', desc: 'The three small hits, the recovery timeline, and the shopping-window rule.', cluster: 'Refinance' },
  { slug: 'how-car-loan-interest-works', title: 'How Car Loan Interest Works', desc: 'What 48 vs 84 months really costs, negative equity, and the 20/4/10 sanity check.', cluster: 'Auto' },
  { slug: 'new-vs-used-car-loan', title: 'New vs. Used Car Loans: The Real Math', desc: 'Used finances worse but costs less — a worked comparison including depreciation.', cluster: 'Auto' },
  { slug: 'upside-down-car-loan', title: 'Upside Down on a Car Loan: Options', desc: 'Five real exits ranked — and why rolling the gap forward digs the deepest hole.', cluster: 'Auto' },
  { slug: 'trade-in-sales-tax', title: 'Trade-Ins & Sales Tax, State by State', desc: 'Most states tax the price after trade-in credit — which don’t, and how payoffs flow through.', cluster: 'Auto' },
  { slug: '20-4-10-rule', title: 'The 20/4/10 Car Buying Rule', desc: 'What each number protects, which to bend first, and how to apply it with the calculators.', cluster: 'Auto' },
];

const title = 'Guides — Money Math Explained with Real Numbers | Payoff Logic';
const description =
  'Plain-English guides to mortgage, debt, and loan math — every example computed with the same verified engines that power our calculators, every guide paired with a free tool.';

const schema = [
  {
    '@context': 'https://schema.org',
    '@type': 'BreadcrumbList',
    itemListElement: [
      { '@type': 'ListItem', position: 1, name: 'Home', item: SITE.url },
      { '@type': 'ListItem', position: 2, name: 'Guides', item: SITE.url + '/guides/' },
    ],
  },
];
---

<BaseLayout title={title} description={description} schema={schema}>
  <Breadcrumbs crumbs={[{ label: 'Guides' }]} />

  <div class="mx-auto max-w-5xl px-4 pb-4 sm:px-6">
    <header class="flex items-start justify-between gap-6 py-5">
      <div class="min-w-0">
        <h1 class="text-2xl font-bold text-navy-900 sm:text-3xl">Guides</h1>
        <p class="mt-2 max-w-3xl text-sm leading-relaxed text-navy-700 sm:text-base">
          The math behind the money decisions, in plain English. Every number in these
          guides is computed by the same verified engines that power our calculators —
          and every guide pairs with a free tool for your own numbers.
        </p>
      </div>
      <Illustration kind="hero" class="hidden w-44 shrink-0 sm:block" />
    </header>

    <ul class="mt-4 grid gap-4 sm:grid-cols-2">
      {guides.map((g) => (
        <li class="relative flex flex-col rounded-lg border border-navy-100 bg-white p-5 shadow-sm">
          <p class="text-xs font-semibold tracking-wide text-accent-700 uppercase">{g.cluster}</p>
          <h2 class="mt-1 text-lg font-semibold text-navy-900">
            <a href={`/guides/${g.slug}/`} class="after:absolute after:inset-0 hover:text-navy-600">{g.title}</a>
          </h2>
          <p class="mt-2 flex-1 text-sm leading-relaxed text-navy-600">{g.desc}</p>
        </li>
      ))}
    </ul>
  </div>
</BaseLayout>
