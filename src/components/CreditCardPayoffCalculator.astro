---
/** Credit card payoff island: fixed payment → time, or goal months → payment. */
---

<section id="calc" class="rounded-xl border border-navy-100 bg-white shadow-sm" aria-label="Credit card payoff calculator">
  <div class="grid gap-0 lg:grid-cols-[minmax(0,24rem)_1fr]">
    <form id="calc-form" class="space-y-4 border-b border-navy-100 p-5 sm:p-6 lg:border-r lg:border-b-0" novalidate>
      <div class="grid grid-cols-2 gap-3">
        <div>
          <label for="balance" class="fc-label">Card balance</label>
          <div class="fc-wrap"><span class="fc-prefix">$</span>
            <input id="balance" inputmode="decimal" value="5,000" class="fc-input fc-input--pre" />
          </div>
        </div>
        <div>
          <label for="rate" class="fc-label">APR</label>
          <div class="fc-wrap">
            <input id="rate" inputmode="decimal" value="24" class="fc-input fc-input--suf" />
            <span class="fc-suffix">%</span>
          </div>
        </div>
      </div>
      <fieldset class="rounded-lg border border-navy-100 p-3">
        <legend class="px-1 text-xs font-semibold tracking-wide text-navy-600 uppercase">Choose your question</legend>
        <label class="flex items-start gap-2 text-sm text-navy-700">
          <input type="radio" name="mode" id="mode-pay" checked class="mt-0.5" />
          <span>“If I pay a fixed amount monthly, when am I done?”</span>
        </label>
        <div class="mt-2 pl-6">
          <div class="fc-wrap max-w-40"><span class="fc-prefix">$</span>
            <input id="payment" inputmode="decimal" value="200" class="fc-input fc-input--pre" />
          </div>
        </div>
        <label class="mt-3 flex items-start gap-2 text-sm text-navy-700">
          <input type="radio" name="mode" id="mode-goal" class="mt-0.5" />
          <span>“I want to be done in N months — what payment?”</span>
        </label>
        <div class="mt-2 pl-6">
          <input id="goal" inputmode="numeric" value="24" class="fc-input max-w-40" aria-label="Months to payoff goal" />
        </div>
      </fieldset>
      <p id="calc-error" class="hidden text-sm font-medium text-red-700" role="alert"></p>
      <div class="flex flex-wrap gap-2 pt-1">
        <button type="button" id="share" class="fc-btn">Copy shareable link</button>
        <button type="button" id="print" class="fc-btn fc-btn--ghost">Print results</button>
      </div>
    </form>

    <div class="p-5 sm:p-6">
      <h2 class="text-sm font-semibold tracking-wide text-navy-600 uppercase" id="headline-label">Debt-free in</h2>
      <p class="mt-1 text-4xl font-bold text-navy-900" id="headline" aria-live="polite">—</p>
      <p class="mt-1 text-sm text-navy-700" id="subline">—</p>

      <h3 class="mt-6 text-sm font-semibold tracking-wide text-navy-600 uppercase">What different payments do</h3>
      <div class="mt-2 overflow-x-auto">
        <table class="w-full min-w-[380px] text-sm">
          <thead>
            <tr class="border-b border-navy-200 text-left text-xs font-semibold tracking-wide text-navy-600 uppercase">
              <th class="py-2 pr-2">Fixed payment</th><th class="py-2 pr-2 text-right">Time to zero</th><th class="py-2 text-right">Total interest</th>
            </tr>
          </thead>
          <tbody id="ladder" class="text-navy-800"></tbody>
        </table>
      </div>
      <p id="warning" class="mt-3 hidden rounded-lg bg-amber-50 p-3 text-sm font-medium text-amber-900"></p>
    </div>
  </div>

  <div class="border-t border-navy-100 p-5 sm:p-6">
    <div class="flex flex-wrap items-center justify-between gap-2">
      <h2 class="text-lg font-bold text-navy-900">Payoff schedule</h2>
      <button type="button" id="expand-all" class="text-sm font-medium text-navy-700 underline hover:text-navy-900">Expand all years</button>
    </div>
    <div id="schedule" class="mt-4 space-y-1"></div>
  </div>
</section>

<script>
  import { pmt, amortizeLoan } from '../lib/loan.js';
  import { fmt0, fmt2, num, byId, input, yrMo, renderYearSchedule, urlState, wireActions, onInput } from '../lib/ui.js';

  const url = urlState(['balance', 'rate', 'payment', 'goal', 'mode-goal']);

  function recalc() {
    const balance = num(input('balance'));
    const rate = num(input('rate'));
    const goalMode = input('mode-goal').checked;
    const err = byId('calc-error');
    let msg = null;
    if (balance <= 0) msg = 'Enter a balance above $0.';
    else if (rate < 0 || rate > 50) msg = 'Enter an APR between 0% and 50%.';
    if (msg) { err.textContent = msg; err.classList.remove('hidden'); return; }
    err.classList.add('hidden');

    const minInterest = (balance * rate) / 100 / 12;
    let payment;
    if (goalMode) {
      const months = Math.max(1, Math.round(num(input('goal'))));
      payment = pmt(balance, rate, months);
      byId('headline-label').textContent = 'Required monthly payment';
      byId('headline').textContent = fmt2.format(payment);
      const a = amortizeLoan({ principal: balance, annualRate: rate, payment });
      byId('subline').textContent = `Pays off ${fmt0.format(balance)} in ${months} months with ${fmt0.format(a.totalInterest)} total interest.`;
      renderYearSchedule(byId('schedule'), a.rows);
    } else {
      payment = num(input('payment'));
      byId('headline-label').textContent = 'Debt-free in';
      if (payment <= minInterest) {
        byId('headline').textContent = 'never';
        byId('subline').textContent = `Interest alone is ${fmt2.format(minInterest)}/month — a ${fmt2.format(payment)} payment can't outrun it. Increase the payment above ${fmt0.format(minInterest + 1)}.`;
        byId('schedule').innerHTML = '';
      } else {
        const a = amortizeLoan({ principal: balance, annualRate: rate, payment });
        byId('headline').textContent = yrMo(a.months);
        byId('subline').textContent = `${a.months} payments of ${fmt2.format(payment)} · total interest ${fmt0.format(a.totalInterest)}.`;
        renderYearSchedule(byId('schedule'), a.rows);
      }
    }

    const base = goalMode ? pmt(balance, rate, Math.max(1, Math.round(num(input('goal'))))) : num(input('payment'));
    byId('ladder').innerHTML = [base, base + 50, base + 100, base + 200]
      .map((p) => {
        if (p <= minInterest) return `<tr class="border-b border-navy-50"><td class="py-2 pr-2">${fmt0.format(p)}</td><td class="py-2 pr-2 text-right">never (below interest)</td><td class="py-2 text-right">—</td></tr>`;
        const a = amortizeLoan({ principal: balance, annualRate: rate, payment: p });
        return `<tr class="border-b border-navy-50${p === base ? ' bg-accent-50 font-semibold' : ''}"><td class="py-2 pr-2">${fmt0.format(p)}</td><td class="py-2 pr-2 text-right tabular-nums">${yrMo(a.months)}</td><td class="py-2 text-right tabular-nums">${fmt0.format(a.totalInterest)}</td></tr>`;
      })
      .join('');

    const warn = byId('warning');
    if (!goalMode && num(input('payment')) > 0 && num(input('payment')) < minInterest * 1.5) {
      warn.textContent = `Heads up: at ${fmt2.format(num(input('payment')))} you're paying mostly interest (${fmt2.format(minInterest)}/month of it). Card minimums are designed this way — see the guide below.`;
      warn.classList.remove('hidden');
    } else warn.classList.add('hidden');
    url.sync();
  }

  url.load();
  if (new URLSearchParams(location.search).get('mode-goal') === '1') input('mode-goal').checked = true;
  onInput('calc-form', recalc);
  byId('calc-form').addEventListener('change', recalc);
  wireActions('#schedule');
  recalc();
</script>
