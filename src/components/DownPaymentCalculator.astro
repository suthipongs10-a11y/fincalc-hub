---
/** Down payment island: scenario table across 3.5–20% + cash-to-close. */
---

<section id="calc" class="rounded-xl border border-navy-100 bg-white shadow-sm" aria-label="Down payment calculator">
  <div class="grid gap-0 lg:grid-cols-[minmax(0,22rem)_1fr]">
    <form id="calc-form" class="space-y-4 border-b border-navy-100 p-5 sm:p-6 lg:border-r lg:border-b-0" novalidate>
      <div><label for="price" class="fc-label">Home price</label>
        <div class="fc-wrap"><span class="fc-prefix">$</span><input id="price" inputmode="decimal" value="400,000" class="fc-input fc-input--pre" /></div></div>
      <div class="grid grid-cols-2 gap-3">
        <div><label for="rate" class="fc-label">Interest rate</label>
          <div class="fc-wrap"><input id="rate" inputmode="decimal" value="6.5" class="fc-input fc-input--suf" /><span class="fc-suffix">%</span></div></div>
        <div><label for="savings" class="fc-label">Cash you have saved</label>
          <div class="fc-wrap"><span class="fc-prefix">$</span><input id="savings" inputmode="decimal" value="45,000" class="fc-input fc-input--pre" /></div></div>
      </div>
      <p class="text-xs text-navy-600">Assumes a 30-year loan, 0.5%/yr PMI when under 20% down, and ~3% of price in closing costs (varies by state and lender).</p>
      <p id="calc-error" class="hidden text-sm font-medium text-red-700" role="alert"></p>
      <div class="flex flex-wrap gap-2 pt-1">
        <button type="button" id="share" class="fc-btn">Copy shareable link</button>
        <button type="button" id="print" class="fc-btn fc-btn--ghost">Print results</button>
      </div>
    </form>

    <div class="p-5 sm:p-6">
      <h2 class="text-sm font-semibold tracking-wide text-navy-600 uppercase">Down payment scenarios</h2>
      <div class="mt-2 overflow-x-auto">
        <table class="w-full min-w-[520px] text-sm">
          <thead><tr class="border-b border-navy-200 text-left text-xs font-semibold tracking-wide text-navy-600 uppercase">
            <th class="py-2 pr-2">Down</th><th class="py-2 pr-2 text-right">Cash needed*</th><th class="py-2 pr-2 text-right">P&amp;I / mo</th><th class="py-2 pr-2 text-right">PMI / mo</th><th class="py-2 text-right">Total / mo</th></tr></thead>
          <tbody id="table" class="text-navy-800"></tbody>
        </table>
      </div>
      <p class="mt-2 text-xs text-navy-600">*Down payment + ~3% closing costs. Highlighted = the largest down payment your savings cover.</p>
      <p id="verdict" class="mt-3 rounded-lg bg-navy-900 p-4 text-sm font-medium text-white" aria-live="polite">—</p>
    </div>
  </div>
</section>

<script>
  import { pmt } from '../lib/loan.js';
  import { fmt0, fmt2, num, byId, input, urlState, wireActions, onInput } from '../lib/ui.js';

  const url = urlState(['price', 'rate', 'savings']);
  const PCTS = [3.5, 5, 10, 15, 20];

  function recalc() {
    const price = num(input('price'));
    const rate = num(input('rate'));
    const savings = num(input('savings'));
    const err = byId('calc-error');
    let msg = null;
    if (price <= 0) msg = 'Enter a home price above $0.';
    else if (rate < 0 || rate > 25) msg = 'Enter a rate between 0% and 25%.';
    if (msg) { err.textContent = msg; err.classList.remove('hidden'); return; }
    err.classList.add('hidden');

    const closing = price * 0.03;
    const rows = PCTS.map((pct) => {
      const down = (price * pct) / 100;
      const loan = price - down;
      const pi = pmt(loan, rate, 360);
      const pmi = pct < 20 ? (loan * 0.5) / 100 / 12 : 0;
      return { pct, down, cash: down + closing, pi, pmi, total: pi + pmi };
    });
    const affordable = [...rows].reverse().find((r) => r.cash <= savings);
    byId('table').innerHTML = rows
      .map((r) => `<tr class="border-b border-navy-50${affordable && r.pct === affordable.pct ? ' bg-accent-50 font-semibold' : ''}">
        <td class="py-2 pr-2">${r.pct}% (${fmt0.format(r.down)})</td>
        <td class="py-2 pr-2 text-right tabular-nums">${fmt0.format(r.cash)}</td>
        <td class="py-2 pr-2 text-right tabular-nums">${fmt2.format(r.pi)}</td>
        <td class="py-2 pr-2 text-right tabular-nums">${r.pmi ? fmt2.format(r.pmi) : '—'}</td>
        <td class="py-2 text-right tabular-nums">${fmt2.format(r.total)}</td></tr>`)
      .join('');

    const r20 = rows[rows.length - 1], r5 = rows[1];
    byId('verdict').textContent = affordable
      ? `Your ${fmt0.format(savings)} covers up to ${affordable.pct}% down on this price (incl. ~${fmt0.format(closing)} closing costs). Going from 5% to 20% down saves ${fmt2.format(r5.total - r20.total)}/month — but never at the cost of an empty emergency fund.`
      : `Your ${fmt0.format(savings)} doesn't yet cover 3.5% down + ~${fmt0.format(closing)} closing costs on this price. Options: a lower price point, down-payment assistance programs, or VA/USDA (zero-down) if eligible.`;
    url.sync();
  }

  url.load();
  onInput('calc-form', recalc);
  wireActions('#calc');
  recalc();
</script>
