---
/** Auto loan island: trade-in, payoff on trade, state sales tax, fees. */
import taxData from '../data/auto-sales-tax.json';
---

<section id="calc" class="rounded-xl border border-navy-100 bg-white shadow-sm" aria-label="Auto loan calculator">
  <div class="grid gap-0 lg:grid-cols-[minmax(0,24rem)_1fr]">
    <form id="calc-form" class="space-y-4 border-b border-navy-100 p-5 sm:p-6 lg:border-r lg:border-b-0" novalidate>
      <div>
        <label for="price" class="fc-label">Vehicle price</label>
        <div class="fc-wrap"><span class="fc-prefix">$</span>
          <input id="price" inputmode="decimal" value="35,000" class="fc-input fc-input--pre" />
        </div>
      </div>
      <div class="grid grid-cols-2 gap-3">
        <div>
          <label for="down" class="fc-label">Down payment</label>
          <div class="fc-wrap"><span class="fc-prefix">$</span>
            <input id="down" inputmode="decimal" value="4,000" class="fc-input fc-input--pre" />
          </div>
        </div>
        <div>
          <label for="trade" class="fc-label">Trade-in value</label>
          <div class="fc-wrap"><span class="fc-prefix">$</span>
            <input id="trade" inputmode="decimal" value="0" class="fc-input fc-input--pre" />
          </div>
        </div>
        <div>
          <label for="owed" class="fc-label">Still owed on trade</label>
          <div class="fc-wrap"><span class="fc-prefix">$</span>
            <input id="owed" inputmode="decimal" value="0" class="fc-input fc-input--pre" />
          </div>
        </div>
        <div>
          <label for="fees" class="fc-label">Title, doc &amp; reg. fees</label>
          <div class="fc-wrap"><span class="fc-prefix">$</span>
            <input id="fees" inputmode="decimal" value="400" class="fc-input fc-input--pre" />
          </div>
        </div>
      </div>

      <fieldset class="rounded-lg border border-navy-100 p-3">
        <legend class="px-1 text-xs font-semibold tracking-wide text-navy-600 uppercase">Sales tax</legend>
        <div class="grid grid-cols-2 gap-3">
          <div>
            <label for="state" class="fc-label">State</label>
            <select id="state" class="fc-input">
              <option value="">— Select —</option>
              {taxData.states.map((s) => <option value={s.code} data-rate={s.rate} data-credit={s.tradeInCredit ? '1' : '0'}>{s.name}</option>)}
            </select>
          </div>
          <div>
            <label for="tax-rate" class="fc-label">Tax rate</label>
            <div class="fc-wrap">
              <input id="tax-rate" inputmode="decimal" value="6" class="fc-input fc-input--suf" />
              <span class="fc-suffix">%</span>
            </div>
          </div>
        </div>
        <label class="mt-3 flex items-start gap-2 text-sm text-navy-700">
          <input id="trade-credit" type="checkbox" checked class="mt-0.5" />
          <span>My state taxes the price <em>after</em> the trade-in credit</span>
        </label>
        <p id="state-note" class="mt-2 text-xs text-navy-600">Pick a state to prefill its base rate — local county/city taxes often add more, so adjust the rate to match your area.</p>
      </fieldset>

      <div class="grid grid-cols-2 gap-3">
        <div>
          <label for="rate" class="fc-label">Interest rate (APR)</label>
          <div class="fc-wrap">
            <input id="rate" inputmode="decimal" value="7" class="fc-input fc-input--suf" />
            <span class="fc-suffix">%</span>
          </div>
        </div>
        <div>
          <label for="term" class="fc-label">Loan term</label>
          <select id="term" class="fc-input">
            <option value="36">36 months</option>
            <option value="48">48 months</option>
            <option value="60" selected>60 months</option>
            <option value="72">72 months</option>
            <option value="84">84 months</option>
          </select>
        </div>
      </div>
      <label class="flex items-start gap-2 text-sm text-navy-700">
        <input id="finance-tax" type="checkbox" checked class="mt-0.5" />
        <span>Roll sales tax &amp; fees into the loan</span>
      </label>

      <p id="calc-error" class="hidden text-sm font-medium text-red-700" role="alert"></p>
      <div class="flex flex-wrap gap-2 pt-1">
        <button type="button" id="share" class="fc-btn">Copy shareable link</button>
        <button type="button" id="print" class="fc-btn fc-btn--ghost">Print results</button>
      </div>
    </form>

    <div class="p-5 sm:p-6">
      <h2 class="text-sm font-semibold tracking-wide text-navy-600 uppercase">Estimated monthly payment</h2>
      <p class="mt-1 text-4xl font-bold text-navy-900" id="payment" aria-live="polite">—</p>

      <h3 class="mt-6 text-sm font-semibold tracking-wide text-navy-600 uppercase">How your loan amount is built</h3>
      <div class="mt-2 overflow-x-auto">
        <table class="w-full min-w-[360px] text-sm"><tbody id="build-body" class="text-navy-800"></tbody></table>
      </div>

      <div class="mt-6 grid gap-3 sm:grid-cols-3">
        <div class="rounded-lg bg-navy-50 p-3">
          <p class="text-xs font-medium text-navy-600">Amount financed</p>
          <p id="loan" class="text-lg font-bold text-navy-900">—</p>
        </div>
        <div class="rounded-lg bg-navy-50 p-3">
          <p class="text-xs font-medium text-navy-600">Total interest</p>
          <p id="tint" class="text-lg font-bold text-navy-900">—</p>
        </div>
        <div class="rounded-lg bg-navy-50 p-3">
          <p class="text-xs font-medium text-navy-600">Due at signing</p>
          <p id="upfront" class="text-lg font-bold text-navy-900">—</p>
        </div>
      </div>
      <p id="negative-equity" class="mt-3 hidden rounded-lg bg-amber-50 p-3 text-sm font-medium text-amber-900"></p>
    </div>
  </div>

  <div class="border-t border-navy-100 p-5 sm:p-6">
    <div class="flex flex-wrap items-center justify-between gap-2">
      <h2 class="text-lg font-bold text-navy-900">Amortization schedule</h2>
      <button type="button" id="expand-all" class="text-sm font-medium text-navy-700 underline hover:text-navy-900">Expand all years</button>
    </div>
    <div id="schedule" class="mt-4 space-y-1"></div>
  </div>
</section>

<script>
  import { computeAuto } from '../lib/auto.js';
  import taxData from '../data/auto-sales-tax.json';
  import { fmt0, fmt2, num, byId, input, renderYearSchedule, urlState, wireActions, onInput } from '../lib/ui.js';

  const url = urlState(['price', 'down', 'trade', 'owed', 'fees', 'state', 'tax-rate', 'trade-credit', 'rate', 'term', 'finance-tax']);

  function applyState() {
    const sel = /** @type {HTMLSelectElement} */ (input('state'));
    const st = taxData.states.find((s) => s.code === sel.value);
    const note = byId('state-note');
    if (st) {
      input('tax-rate').value = String(st.rate);
      input('trade-credit').checked = st.tradeInCredit;
      note.textContent = `${st.name}: ${st.rate}% state base rate${st.tradeInCredit ? ', trade-in reduces taxable amount' : ' on the FULL price (no trade-in credit)'}. ${st.note || 'Local taxes may add more — adjust the rate for your area.'}`;
    }
  }

  function recalc() {
    const o = {
      price: num(input('price')),
      down: num(input('down')),
      tradeIn: num(input('trade')),
      owedOnTrade: num(input('owed')),
      taxRate: num(input('tax-rate')),
      tradeInReducesTax: input('trade-credit').checked,
      fees: num(input('fees')),
      financeTaxFees: input('finance-tax').checked,
      annualRate: num(input('rate')),
      termMonths: parseInt(input('term').value, 10),
      startYear: new Date().getFullYear(),
      startMonth: new Date().getMonth() + 1,
    };
    const err = byId('calc-error');
    let msg = null;
    if (o.price <= 0) msg = 'Enter a vehicle price above $0.';
    else if (o.annualRate < 0 || o.annualRate > 30) msg = 'Enter an APR between 0% and 30%.';
    else if (o.down + o.tradeIn > o.price + o.owedOnTrade) msg = 'Down payment plus trade-in exceeds what you owe — you may not need a loan.';
    if (msg) { err.textContent = msg; err.classList.remove('hidden'); return; }
    err.classList.add('hidden');

    const r = computeAuto(o);
    byId('payment').textContent = fmt2.format(r.payment);
    byId('loan').textContent = fmt0.format(r.loan);
    byId('tint').textContent = fmt0.format(r.totalInterest);
    byId('upfront').textContent = fmt0.format(r.upfront);

    byId('build-body').innerHTML = [
      ['Vehicle price', r => fmt0.format(o.price)],
      ['− Trade-in value', () => '−' + fmt0.format(o.tradeIn)],
      ['+ Loan balance on trade', () => '+' + fmt0.format(o.owedOnTrade)],
      ['− Down payment', () => '−' + fmt0.format(o.down)],
      [`${o.financeTaxFees ? '+' : ''} Sales tax (${o.taxRate}% on ${fmt0.format(r.taxable)})${o.financeTaxFees ? '' : ' — paid upfront'}`, () => (o.financeTaxFees ? '+' : '') + fmt0.format(r.salesTax)],
      [`${o.financeTaxFees ? '+' : ''} Fees${o.financeTaxFees ? '' : ' — paid upfront'}`, () => (o.financeTaxFees ? '+' : '') + fmt0.format(o.fees)],
      ['= Amount financed', () => fmt0.format(r.loan)],
    ].map(([k, v], i, arr) => `<tr class="${i === arr.length - 1 ? 'border-t-2 border-navy-300 font-bold' : 'border-b border-navy-50'}"><td class="py-1.5 pr-2 text-navy-700">${k}</td><td class="py-1.5 text-right tabular-nums">${v()}</td></tr>`).join('');

    const neg = byId('negative-equity');
    if (o.owedOnTrade > o.tradeIn) {
      neg.textContent = `You owe ${fmt0.format(o.owedOnTrade - o.tradeIn)} more on your trade-in than it's worth. That negative equity is rolled into this loan, so you start ${fmt0.format(o.owedOnTrade - o.tradeIn)} underwater on the new car.`;
      neg.classList.remove('hidden');
    } else neg.classList.add('hidden');

    renderYearSchedule(byId('schedule'), r.rows);
    url.sync();
  }

  // url.load() restores state + custom tax-rate/credit from a shared link,
  // so applyState (which overwrites them with state defaults) only runs on
  // user-initiated changes.
  url.load();
  input('state').addEventListener('change', () => { applyState(); recalc(); });
  onInput('calc-form', recalc);
  wireActions('#schedule');
  recalc();
</script>
