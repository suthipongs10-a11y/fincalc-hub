---
/** Rent vs buy island: cumulative net cost paths + crossover year. */
---

<section id="calc" class="rounded-xl border border-navy-100 bg-white shadow-sm" aria-label="Rent vs buy calculator">
  <div class="grid gap-0 lg:grid-cols-[minmax(0,24rem)_1fr]">
    <form id="calc-form" class="space-y-4 border-b border-navy-100 p-5 sm:p-6 lg:border-r lg:border-b-0" novalidate>
      <fieldset class="rounded-lg border border-navy-100 p-3">
        <legend class="px-1 text-xs font-semibold tracking-wide text-navy-600 uppercase">Buying</legend>
        <div class="grid grid-cols-2 gap-3">
          <div><label for="price" class="fc-label">Home price</label>
            <div class="fc-wrap"><span class="fc-prefix">$</span><input id="price" inputmode="decimal" value="400,000" class="fc-input fc-input--pre" /></div></div>
          <div><label for="down" class="fc-label">Down payment</label>
            <div class="fc-wrap"><span class="fc-prefix">$</span><input id="down" inputmode="decimal" value="80,000" class="fc-input fc-input--pre" /></div></div>
          <div><label for="rate" class="fc-label">Rate (30-yr)</label>
            <div class="fc-wrap"><input id="rate" inputmode="decimal" value="6.5" class="fc-input fc-input--suf" /><span class="fc-suffix">%</span></div></div>
          <div><label for="tax" class="fc-label">Property tax / yr</label>
            <div class="fc-wrap"><input id="tax" inputmode="decimal" value="1.1" class="fc-input fc-input--suf" /><span class="fc-suffix">%</span></div></div>
          <div><label for="ins" class="fc-label">Insurance / yr</label>
            <div class="fc-wrap"><span class="fc-prefix">$</span><input id="ins" inputmode="decimal" value="2,000" class="fc-input fc-input--pre" /></div></div>
          <div><label for="maint" class="fc-label">Maintenance / yr</label>
            <div class="fc-wrap"><input id="maint" inputmode="decimal" value="1" class="fc-input fc-input--suf" /><span class="fc-suffix">%</span></div></div>
          <div><label for="appr" class="fc-label">Home appreciation</label>
            <div class="fc-wrap"><input id="appr" inputmode="decimal" value="3" class="fc-input fc-input--suf" /><span class="fc-suffix">%</span></div></div>
        </div>
      </fieldset>
      <fieldset class="rounded-lg border border-navy-100 p-3">
        <legend class="px-1 text-xs font-semibold tracking-wide text-navy-600 uppercase">Renting</legend>
        <div class="grid grid-cols-2 gap-3">
          <div><label for="rent" class="fc-label">Monthly rent</label>
            <div class="fc-wrap"><span class="fc-prefix">$</span><input id="rent" inputmode="decimal" value="2,200" class="fc-input fc-input--pre" /></div></div>
          <div><label for="rentg" class="fc-label">Rent growth / yr</label>
            <div class="fc-wrap"><input id="rentg" inputmode="decimal" value="3" class="fc-input fc-input--suf" /><span class="fc-suffix">%</span></div></div>
        </div>
      </fieldset>
      <div><label for="horizon" class="fc-label">How long will you stay?</label>
        <select id="horizon" class="fc-input">
          <option value="5">5 years</option><option value="7">7 years</option>
          <option value="10" selected>10 years</option><option value="15">15 years</option>
        </select></div>
      <p id="calc-error" class="hidden text-sm font-medium text-red-700" role="alert"></p>
      <div class="flex flex-wrap gap-2 pt-1">
        <button type="button" id="share" class="fc-btn">Copy shareable link</button>
        <button type="button" id="print" class="fc-btn fc-btn--ghost">Print results</button>
      </div>
    </form>

    <div class="p-5 sm:p-6">
      <p id="verdict" class="rounded-lg bg-navy-900 p-4 text-sm font-medium text-white" aria-live="polite">—</p>
      <h2 class="mt-6 text-sm font-semibold tracking-wide text-navy-600 uppercase">Cumulative net cost by year</h2>
      <div class="mt-2 overflow-x-auto">
        <table class="w-full min-w-[380px] text-sm">
          <thead><tr class="border-b border-navy-200 text-left text-xs font-semibold tracking-wide text-navy-600 uppercase">
            <th class="py-2 pr-2">Year</th><th class="py-2 pr-2 text-right">Renting</th><th class="py-2 pr-2 text-right">Owning (net of equity)</th><th class="py-2 text-right">Cheaper</th></tr></thead>
          <tbody id="table" class="text-navy-800"></tbody>
        </table>
      </div>
      <p class="mt-3 text-xs leading-relaxed text-navy-600">
        Owning cost = down payment + ~3% buying costs + payments, taxes, insurance,
        maintenance, minus your equity if you sold that year (after ~7% selling costs).
        Renting cost = rent with annual growth. Not modeled: tax deductions, HOA, rent
        deposits, investment returns on the down payment — adjust inputs to stress-test.
      </p>
    </div>
  </div>
</section>

<script>
  import { rentVsBuy } from '../lib/tools-extra.js';
  import { fmt0, num, byId, input, urlState, wireActions, onInput } from '../lib/ui.js';

  const url = urlState(['price', 'down', 'rate', 'tax', 'ins', 'maint', 'appr', 'rent', 'rentg', 'horizon']);

  function recalc() {
    const o = {
      price: num(input('price')), down: num(input('down')), rate: num(input('rate')),
      termYears: 30, taxRate: num(input('tax')), insAnnual: num(input('ins')),
      maintPct: num(input('maint')), rent: num(input('rent')), rentGrowthPct: num(input('rentg')),
      appreciationPct: num(input('appr')), horizonYears: parseInt(input('horizon').value, 10),
    };
    const err = byId('calc-error');
    let msg = null;
    if (o.price <= 0 || o.rent <= 0) msg = 'Enter a home price and a monthly rent.';
    else if (o.down < 0 || o.down >= o.price) msg = 'Down payment must be between $0 and the price.';
    else if (o.rate < 0 || o.rate > 25) msg = 'Rate must be between 0% and 25%.';
    if (msg) { err.textContent = msg; err.classList.remove('hidden'); return; }
    err.classList.add('hidden');

    const r = rentVsBuy(o);
    const last = r.years[r.years.length - 1];
    byId('verdict').textContent = r.crossover
      ? `Buying overtakes renting in year ${r.crossover}. Staying ${o.horizonYears} years, owning nets out ${fmt0.format(Math.abs(last.rentCost - last.ownCost))} ${last.ownCost < last.rentCost ? 'cheaper' : 'more expensive'} than renting under these assumptions.`
      : `Under these assumptions renting stays cheaper for the full ${o.horizonYears}-year horizon (by ${fmt0.format(last.ownCost - last.rentCost)}). Longer stays, lower prices, or faster rent growth shift the answer.`;

    byId('table').innerHTML = r.years
      .map((y) => `<tr class="border-b border-navy-50${y.y === r.crossover ? ' bg-accent-50 font-semibold' : ''}">
        <td class="py-2 pr-2">${y.y}</td>
        <td class="py-2 pr-2 text-right tabular-nums">${fmt0.format(y.rentCost)}</td>
        <td class="py-2 pr-2 text-right tabular-nums">${fmt0.format(y.ownCost)}</td>
        <td class="py-2 text-right">${y.ownCost < y.rentCost ? 'Buy' : 'Rent'}</td></tr>`)
      .join('');
    url.sync();
  }

  url.load();
  onInput('calc-form', recalc);
  byId('calc-form').addEventListener('change', recalc);
  wireActions('#calc');
  recalc();
</script>
