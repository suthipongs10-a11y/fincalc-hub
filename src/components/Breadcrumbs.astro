---
interface Crumb {
  label: string;
  href?: string;
}
interface Props {
  crumbs: Crumb[];
}
const { crumbs } = Astro.props;
---

<nav aria-label="Breadcrumb" class="mx-auto max-w-5xl px-4 pt-4 sm:px-6">
  <ol class="flex flex-wrap items-center gap-1 text-sm text-navy-600">
    <li><a href="/" class="hover:text-navy-900 hover:underline">Home</a></li>
    {
      crumbs.map((c) => (
        <li class="flex items-center gap-1">
          <span aria-hidden="true">›</span>
          {c.href ? (
            <a href={c.href} class="hover:text-navy-900 hover:underline">{c.label}</a>
          ) : (
            <span aria-current="page" class="font-medium text-navy-900">{c.label}</span>
          )}
        </li>
      ))
    }
  </ol>
</nav>
