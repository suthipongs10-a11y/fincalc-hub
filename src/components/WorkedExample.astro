---
/**
 * "Worked example" section for tool pages: a plain-language setup sentence,
 * a compact figures table, and takeaway prose (default slot). Every figure
 * is computed by the production engine (scripts/worked-examples.mjs) so the
 * example can never contradict the calculator above it.
 */
interface Row {
  label: string;
  value: string;
  strong?: boolean;
}
const { setup, rows = [] } = Astro.props as { setup: string; rows: Row[] };
---

<section>
  <h2 class="text-xl font-bold text-navy-900">Worked example</h2>
  <p class="mt-3">{setup}</p>
  <div class="mt-4 overflow-x-auto rounded-lg border border-navy-100">
    <table class="w-full text-sm">
      <tbody>
        {
          rows.map((r, i) => (
            <tr class:list={[i % 2 ? 'bg-navy-50/50' : 'bg-white']}>
              <th scope="row" class="px-4 py-2 text-left font-medium text-navy-700">{r.label}</th>
              <td class:list={['px-4 py-2 text-right font-mono whitespace-nowrap', r.strong ? 'font-bold text-navy-900' : 'text-navy-800']}>
                {r.value}
              </td>
            </tr>
          ))
        }
      </tbody>
    </table>
  </div>
  <slot />
</section>
