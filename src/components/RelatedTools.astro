---
import { TOOLS } from '../config';

interface Props {
  currentSlug: string;
  /** Curated related slugs (SEO_PLAN: ~3–5 contextual links). Falls back to same-cluster tools + core tools. */
  slugs?: string[];
}
const { currentSlug, slugs } = Astro.props;
const current = TOOLS.find((t) => t.slug === currentSlug);
const related = slugs
  ? slugs.map((s) => TOOLS.find((t) => t.slug === s)).filter((t) => !!t)
  : TOOLS.filter((t) => t.slug !== currentSlug && (t.cluster === current?.cluster || t.core)).slice(0, 6);
---

<section>
  <h2 class="text-xl font-bold text-navy-900">Related calculators</h2>
  <ul class="mt-3 list-disc space-y-1 pl-6">
    {
      related.map((t) => (
        <li>
          {t.status === 'coming-soon' ? (
            <span>{t.name} <span class="text-sm text-navy-500">(coming soon)</span></span>
          ) : (
            <a href={`/${t.slug}/`} class="font-medium text-navy-900 underline hover:text-navy-600">{t.name}</a>
          )}{' '}
          — {t.description}
        </li>
      ))
    }
  </ul>
</section>
