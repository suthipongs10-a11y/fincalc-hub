---
/** Loan payoff island: extra payments → time saved + interest saved. */
---

<section id="calc" class="rounded-xl border border-navy-100 bg-white shadow-sm" aria-label="Loan payoff calculator">
  <div class="grid gap-0 lg:grid-cols-[minmax(0,24rem)_1fr]">
    <form id="calc-form" class="space-y-4 border-b border-navy-100 p-5 sm:p-6 lg:border-r lg:border-b-0" novalidate>
      <div>
        <label for="balance" class="fc-label">Current loan balance</label>
        <div class="fc-wrap"><span class="fc-prefix">$</span>
          <input id="balance" inputmode="decimal" value="20,000" class="fc-input fc-input--pre" />
        </div>
      </div>
      <div class="grid grid-cols-2 gap-3">
        <div>
          <label for="rate" class="fc-label">Interest rate (APR)</label>
          <div class="fc-wrap">
            <input id="rate" inputmode="decimal" value="6.5" class="fc-input fc-input--suf" />
            <span class="fc-suffix">%</span>
          </div>
        </div>
        <div>
          <label for="payment" class="fc-label">Monthly payment</label>
          <div class="fc-wrap"><span class="fc-prefix">$</span>
            <input id="payment" inputmode="decimal" value="400" class="fc-input fc-input--pre" />
          </div>
        </div>
      </div>
      <p class="text-xs text-navy-600">Enter the principal-and-interest part of your payment (exclude escrow, taxes, or insurance).</p>
      <div class="grid grid-cols-2 gap-3">
        <div>
          <label for="extra" class="fc-label">Extra payment / month</label>
          <div class="fc-wrap"><span class="fc-prefix">$</span>
            <input id="extra" inputmode="decimal" value="100" class="fc-input fc-input--pre" />
          </div>
        </div>
        <div>
          <label for="start" class="fc-label">Next payment</label>
          <input id="start" type="month" class="fc-input" />
        </div>
      </div>
      <p id="calc-error" class="hidden text-sm font-medium text-red-700" role="alert"></p>
      <div class="flex flex-wrap gap-2 pt-1">
        <button type="button" id="share" class="fc-btn">Copy shareable link</button>
        <button type="button" id="print" class="fc-btn fc-btn--ghost">Print results</button>
      </div>
    </form>

    <div class="p-5 sm:p-6">
      <div class="grid gap-3 sm:grid-cols-2">
        <div class="rounded-lg bg-navy-50 p-4">
          <p class="text-xs font-semibold tracking-wide text-navy-600 uppercase">Current plan</p>
          <p class="mt-1 text-2xl font-bold text-navy-900" id="base-time">—</p>
          <p class="text-sm text-navy-700">Debt-free <span id="base-date">—</span></p>
          <p class="mt-1 text-sm text-navy-700">Interest: <strong id="base-int">—</strong></p>
        </div>
        <div class="rounded-lg bg-accent-50 p-4">
          <p class="text-xs font-semibold tracking-wide text-accent-800 uppercase">With extra payments</p>
          <p class="mt-1 text-2xl font-bold text-accent-800" id="extra-time" aria-live="polite">—</p>
          <p class="text-sm text-accent-800">Debt-free <span id="extra-date">—</span></p>
          <p class="mt-1 text-sm text-accent-800">Interest: <strong id="extra-int">—</strong></p>
        </div>
      </div>
      <p id="savings" class="mt-3 rounded-lg bg-navy-900 p-4 text-sm font-medium text-white">—</p>

      <h2 class="mt-8 text-sm font-semibold tracking-wide text-navy-600 uppercase">Balance over time</h2>
      <div class="mt-2 overflow-x-auto">
        <svg id="chart" viewBox="0 0 640 240" class="h-auto w-full min-w-[420px]" role="img" aria-label="Loan balance by year, with and without extra payments"></svg>
      </div>
      <p class="mt-1 text-xs text-navy-600">Solid: with extra payments · Dashed: current plan.</p>
    </div>
  </div>

  <div class="border-t border-navy-100 p-5 sm:p-6">
    <div class="flex flex-wrap items-center justify-between gap-2">
      <h2 class="text-lg font-bold text-navy-900">Payoff schedule (with extra payments)</h2>
      <button type="button" id="expand-all" class="text-sm font-medium text-navy-700 underline hover:text-navy-900">Expand all years</button>
    </div>
    <div id="schedule" class="mt-4 space-y-1"></div>
  </div>
</section>

<script>
  import { amortizeLoan } from '../lib/loan.js';
  import { fmt0, num, byId, input, yrMo, payoffLabel, renderYearSchedule, drawBalanceChart, rowsToSeries, urlState, wireActions, onInput } from '../lib/ui.js';

  const url = urlState(['balance', 'rate', 'payment', 'extra', 'start']);

  function defaultStart() {
    const d = new Date();
    d.setMonth(d.getMonth() + 1);
    return `${d.getFullYear()}-${String(d.getMonth() + 1).padStart(2, '0')}`;
  }

  function recalc() {
    const balance = num(input('balance'));
    const rate = num(input('rate'));
    const payment = num(input('payment'));
    const extra = num(input('extra'));
    const [sy, sm] = (input('start').value || defaultStart()).split('-').map(Number);
    const err = byId('calc-error');

    let msg = null;
    if (balance <= 0) msg = 'Enter a loan balance above $0.';
    else if (rate < 0 || rate > 40) msg = 'Enter an APR between 0% and 40%.';
    else if (payment <= 0) msg = 'Enter your monthly payment.';
    else if (payment <= (balance * rate) / 100 / 12)
      msg = `That payment doesn't cover the monthly interest (${fmt0.format((balance * rate) / 100 / 12)}). The balance would grow forever — increase the payment.`;
    if (msg) { err.textContent = msg; err.classList.remove('hidden'); return; }
    err.classList.add('hidden');

    const base = amortizeLoan({ principal: balance, annualRate: rate, payment, startYear: sy, startMonth: sm });
    const boosted = amortizeLoan({ principal: balance, annualRate: rate, payment, extraMonthly: extra, startYear: sy, startMonth: sm });

    byId('base-time').textContent = yrMo(base.months);
    byId('base-date').textContent = payoffLabel(sy, sm, base.months);
    byId('base-int').textContent = fmt0.format(base.totalInterest);
    byId('extra-time').textContent = yrMo(boosted.months);
    byId('extra-date').textContent = payoffLabel(sy, sm, boosted.months);
    byId('extra-int').textContent = fmt0.format(boosted.totalInterest);

    byId('savings').textContent = extra > 0
      ? `Extra ${fmt0.format(extra)}/month makes you debt-free ${yrMo(base.months - boosted.months)} sooner and saves ${fmt0.format(base.totalInterest - boosted.totalInterest)} in interest.`
      : 'Add an extra monthly payment to see how much time and interest you save.';

    drawBalanceChart(byId('chart'), [
      { values: rowsToSeries(base.rows, balance), dashed: true },
      { values: rowsToSeries(boosted.rows, balance) },
    ]);
    renderYearSchedule(byId('schedule'), boosted.rows);
    url.sync();
  }

  input('start').value = defaultStart();
  url.load();
  onInput('calc-form', recalc);
  wireActions('#schedule');
  recalc();
</script>
