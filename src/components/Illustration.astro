---
/**
 * Brand illustration set — pure inline SVG in the design-token palette.
 * Decorative (aria-hidden); crisp at any size; zero network cost.
 * kinds: hero, piti, payoff, snowball, breakeven, car, affordability,
 *        shield, race, map
 */
interface Props {
  kind: string;
  class?: string;
}
const { kind, class: cls = '' } = Astro.props;
const navy9 = '#16243a';
const navy5 = '#3f74aa';
const navy3 = '#92b5d6';
const navy1 = '#dce8f3';
const green = '#10b981';
const greenL = '#6ee7b7';
const amber = '#fbbf24';
---

{kind === 'hero' && (
  <svg viewBox="0 0 280 200" class={cls} aria-hidden="true" fill="none">
    <path d="M20 170 C70 165 90 120 130 95 C180 65 220 55 262 50" stroke={greenL} stroke-width="3" stroke-linecap="round" stroke-dasharray="1 8"/>
    <rect x="26" y="120" width="16" height="50" rx="3" fill={navy5}/>
    <rect x="50" y="100" width="16" height="70" rx="3" fill={navy3}/>
    <rect x="74" y="82" width="16" height="88" rx="3" fill={navy5}/>
    <path d="M150 96 L196 60 L242 96 V164 a6 6 0 0 1 -6 6 H156 a6 6 0 0 1 -6 -6 Z" fill={navy1}/>
    <path d="M138 102 L196 56 L254 102" stroke={green} stroke-width="7" stroke-linecap="round" stroke-linejoin="round"/>
    <rect x="186" y="128" width="22" height="42" rx="2" fill={navy5}/>
    <rect x="160" y="116" width="16" height="16" rx="2" fill={navy3}/>
    <rect x="218" y="116" width="16" height="16" rx="2" fill={navy3}/>
    <circle cx="60" cy="52" r="18" fill={green}/>
    <path d="M60 43 v18 M54 49 h9 a4 4 0 1 1 0 8 h-7" stroke="white" stroke-width="2.6" stroke-linecap="round"/>
  </svg>
)}

{kind === 'piti' && (
  <svg viewBox="0 0 160 120" class={cls} aria-hidden="true" fill="none">
    <path d="M22 54 L52 30 L82 54 V96 a4 4 0 0 1 -4 4 H26 a4 4 0 0 1 -4 -4 Z" fill={navy1}/>
    <path d="M14 58 L52 27 L90 58" stroke={navy9} stroke-width="5" stroke-linecap="round" stroke-linejoin="round"/>
    <rect x="44" y="72" width="16" height="28" rx="2" fill={navy5}/>
    <rect x="104" y="22" width="26" height="24" rx="3" fill={navy9}/>
    <rect x="104" y="50" width="26" height="16" rx="3" fill={navy5}/>
    <rect x="104" y="70" width="26" height="12" rx="3" fill={navy3}/>
    <rect x="104" y="86" width="26" height="12" rx="3" fill={green}/>
  </svg>
)}

{kind === 'payoff' && (
  <svg viewBox="0 0 160 120" class={cls} aria-hidden="true" fill="none">
    <path d="M16 26 C48 30 84 44 104 66 C118 80 130 92 146 98" stroke={navy3} stroke-width="4" stroke-linecap="round" stroke-dasharray="6 6"/>
    <path d="M16 26 C40 34 64 58 76 82 C82 94 86 100 90 104" stroke={navy9} stroke-width="5" stroke-linecap="round"/>
    <circle cx="90" cy="104" r="7" fill={green}/>
    <path d="M90 104 V56" stroke={green} stroke-width="3" stroke-linecap="round"/>
    <path d="M90 56 l22 8 -22 8 Z" fill={green}/>
    <circle cx="140" cy="28" r="14" fill={navy1}/>
    <path d="M134 28 l5 5 8 -10" stroke={green} stroke-width="3" stroke-linecap="round" stroke-linejoin="round"/>
  </svg>
)}

{kind === 'snowball' && (
  <svg viewBox="0 0 160 120" class={cls} aria-hidden="true" fill="none">
    <path d="M6 34 L154 96" stroke={navy3} stroke-width="4" stroke-linecap="round"/>
    <circle cx="34" cy="32" r="12" fill={navy1} stroke={navy5} stroke-width="2"/>
    <circle cx="78" cy="46" r="19" fill={navy1} stroke={navy5} stroke-width="2"/>
    <circle cx="126" cy="60" r="27" fill={navy1} stroke={navy9} stroke-width="3"/>
    <path d="M116 60 h20 M126 50 v20" stroke={green} stroke-width="3.4" stroke-linecap="round"/>
    <path d="M30 28 q4 -3 8 0 M72 40 q6 -4 12 0 M116 50 q10 -6 20 0" stroke={navy3} stroke-width="2" stroke-linecap="round"/>
  </svg>
)}

{kind === 'breakeven' && (
  <svg viewBox="0 0 160 120" class={cls} aria-hidden="true" fill="none">
    <path d="M14 104 H146" stroke={navy3} stroke-width="2"/>
    <path d="M14 104 V16" stroke={navy3} stroke-width="2"/>
    <path d="M20 30 L140 86" stroke={navy9} stroke-width="4.5" stroke-linecap="round"/>
    <path d="M20 88 L140 40" stroke={green} stroke-width="4.5" stroke-linecap="round"/>
    <circle cx="83" cy="60" r="8" fill="white" stroke={amber} stroke-width="4"/>
    <path d="M83 68 V104" stroke={amber} stroke-width="2.4" stroke-dasharray="4 4"/>
  </svg>
)}

{kind === 'car' && (
  <svg viewBox="0 0 160 120" class={cls} aria-hidden="true" fill="none">
    <path d="M22 78 q0 -8 8 -10 l10 -20 q3 -6 10 -6 h44 q7 0 12 5 l17 18 q14 3 14 13 v10 a6 6 0 0 1 -6 6 h-9" stroke={navy9} stroke-width="5" stroke-linejoin="round" fill={navy1}/>
    <path d="M54 48 l-8 18 h34 v-18 Z M88 48 v18 h28 l-14 -15 q-3 -3 -7 -3 Z" fill={navy3}/>
    <circle cx="52" cy="92" r="12" fill="white" stroke={navy9} stroke-width="5"/>
    <circle cx="112" cy="92" r="12" fill="white" stroke={navy9} stroke-width="5"/>
    <rect x="120" y="20" width="26" height="18" rx="4" fill={green}/>
    <path d="M127 29 h12" stroke="white" stroke-width="2.6" stroke-linecap="round"/>
  </svg>
)}

{kind === 'affordability' && (
  <svg viewBox="0 0 160 120" class={cls} aria-hidden="true" fill="none">
    <path d="M28 96 a52 52 0 0 1 104 0" stroke={navy1} stroke-width="12" stroke-linecap="round"/>
    <path d="M28 96 a52 52 0 0 1 62 -51" stroke={green} stroke-width="12" stroke-linecap="round"/>
    <path d="M80 96 L104 62" stroke={navy9} stroke-width="5" stroke-linecap="round"/>
    <circle cx="80" cy="96" r="7" fill={navy9}/>
    <path d="M64 88 L80 75 L96 88 V104 H64 Z" fill="none"/>
  </svg>
)}

{kind === 'shield' && (
  <svg viewBox="0 0 160 120" class={cls} aria-hidden="true" fill="none">
    <path d="M80 12 L124 26 V58 q0 32 -44 48 Q36 90 36 58 V26 Z" fill={navy1} stroke={navy9} stroke-width="5" stroke-linejoin="round"/>
    <path d="M58 58 L80 40 L102 58" stroke={green} stroke-width="5" stroke-linecap="round" stroke-linejoin="round"/>
    <rect x="66" y="58" width="28" height="24" rx="2" fill={navy5}/>
    <rect x="76" y="66" width="8" height="16" rx="1" fill="white"/>
  </svg>
)}

{kind === 'race' && (
  <svg viewBox="0 0 160 120" class={cls} aria-hidden="true" fill="none">
    <rect x="22" y="30" width="82" height="20" rx="10" fill={navy3}/>
    <rect x="22" y="30" width="82" height="20" rx="10" fill="none" stroke={navy5} stroke-width="2"/>
    <rect x="22" y="66" width="118" height="20" rx="10" fill={navy1} stroke={navy3} stroke-width="2"/>
    <rect x="22" y="66" width="58" height="20" rx="10" fill={navy9}/>
    <circle cx="104" cy="40" r="13" fill={green}/>
    <path d="M99 40 l4 4 7 -8" stroke="white" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"/>
    <text x="26" y="24" font-size="11" fill={navy5} font-family="sans-serif" font-weight="700">15 yr</text>
    <text x="26" y="62" font-size="11" fill={navy5} font-family="sans-serif" font-weight="700">30 yr</text>
  </svg>
)}

{kind === 'map' && (
  <svg viewBox="0 0 160 120" class={cls} aria-hidden="true" fill="none">
    {Array.from({ length: 5 }).map((_, r) =>
      Array.from({ length: 8 }).map((_, c) => {
        const colors = [navy1, navy3, navy5, green, navy1, navy3];
        const fill = colors[(r * 3 + c * 5) % colors.length];
        return <rect x={14 + c * 17} y={18 + r * 17} width="13" height="13" rx="3" fill={fill} opacity={r === 4 && c > 5 ? 0 : 1} />;
      })
    )}
    <circle cx="116" cy="52" r="10" fill="none" stroke={navy9} stroke-width="3.4"/>
    <path d="M123 60 l12 12" stroke={navy9} stroke-width="3.4" stroke-linecap="round"/>
  </svg>
)}
