---
/** Car affordability island: monthly budget → max vehicle price (tax-aware). */
---

<section id="calc" class="rounded-xl border border-navy-100 bg-white shadow-sm" aria-label="Car affordability calculator">
  <div class="grid gap-0 lg:grid-cols-[minmax(0,22rem)_1fr]">
    <form id="calc-form" class="space-y-4 border-b border-navy-100 p-5 sm:p-6 lg:border-r lg:border-b-0" novalidate>
      <div><label for="budget" class="fc-label">Monthly payment budget</label>
        <div class="fc-wrap"><span class="fc-prefix">$</span><input id="budget" inputmode="decimal" value="450" class="fc-input fc-input--pre" /></div></div>
      <div class="grid grid-cols-2 gap-3">
        <div><label for="down" class="fc-label">Cash down</label>
          <div class="fc-wrap"><span class="fc-prefix">$</span><input id="down" inputmode="decimal" value="3,000" class="fc-input fc-input--pre" /></div></div>
        <div><label for="trade" class="fc-label">Trade-in value</label>
          <div class="fc-wrap"><span class="fc-prefix">$</span><input id="trade" inputmode="decimal" value="0" class="fc-input fc-input--pre" /></div></div>
        <div><label for="rate" class="fc-label">APR</label>
          <div class="fc-wrap"><input id="rate" inputmode="decimal" value="7" class="fc-input fc-input--suf" /><span class="fc-suffix">%</span></div></div>
        <div><label for="term" class="fc-label">Term</label>
          <select id="term" class="fc-input">
            <option value="36">36 months</option><option value="48">48 months</option>
            <option value="60" selected>60 months</option><option value="72">72 months</option>
          </select></div>
        <div><label for="tax" class="fc-label">Sales tax</label>
          <div class="fc-wrap"><input id="tax" inputmode="decimal" value="6" class="fc-input fc-input--suf" /><span class="fc-suffix">%</span></div></div>
      </div>
      <label class="flex items-start gap-2 text-sm text-navy-700">
        <input id="credit" type="checkbox" checked class="mt-0.5" />
        <span>My state taxes the price <em>after</em> trade-in credit</span>
      </label>
      <p id="calc-error" class="hidden text-sm font-medium text-red-700" role="alert"></p>
      <div class="flex flex-wrap gap-2 pt-1">
        <button type="button" id="share" class="fc-btn">Copy shareable link</button>
        <button type="button" id="print" class="fc-btn fc-btn--ghost">Print results</button>
      </div>
    </form>

    <div class="p-5 sm:p-6">
      <h2 class="text-sm font-semibold tracking-wide text-navy-600 uppercase">You can shop up to about</h2>
      <p class="mt-1 text-4xl font-bold text-navy-900" id="max-price" aria-live="polite">—</p>
      <p class="mt-1 text-sm text-navy-700" id="subline">—</p>
      <h3 class="mt-6 text-sm font-semibold tracking-wide text-navy-600 uppercase">Budget sensitivity</h3>
      <div class="mt-2 overflow-x-auto">
        <table class="w-full min-w-[380px] text-sm">
          <thead><tr class="border-b border-navy-200 text-left text-xs font-semibold tracking-wide text-navy-600 uppercase">
            <th class="py-2 pr-2">Budget / mo</th><th class="py-2 pr-2 text-right">Max price</th><th class="py-2 text-right">Amount financed</th></tr></thead>
          <tbody id="ladder" class="text-navy-800"></tbody>
        </table>
      </div>
      <p class="mt-3 text-xs leading-relaxed text-navy-600">
        Remember the 20/4/10 guideline: total car costs (payment + insurance + fuel)
        under 10% of gross income. Insurance and registration aren't in this loan math —
        budget them separately.
      </p>
    </div>
  </div>
</section>

<script>
  import { carAffordability } from '../lib/tools-extra.js';
  import { fmt0, num, byId, input, urlState, wireActions, onInput } from '../lib/ui.js';

  const url = urlState(['budget', 'down', 'trade', 'rate', 'term', 'tax', 'credit']);

  function recalc() {
    const o = {
      budget: num(input('budget')), down: num(input('down')), tradeIn: num(input('trade')),
      annualRate: num(input('rate')), termMonths: parseInt(input('term').value, 10),
      taxRate: num(input('tax')), tradeInReducesTax: input('credit').checked, feesUpfront: true,
    };
    const err = byId('calc-error');
    let msg = null;
    if (o.budget <= 0) msg = 'Enter a monthly budget above $0.';
    else if (o.annualRate < 0 || o.annualRate > 30) msg = 'Enter an APR between 0% and 30%.';
    if (msg) { err.textContent = msg; err.classList.remove('hidden'); return; }
    err.classList.add('hidden');

    const r = carAffordability(o);
    byId('max-price').textContent = fmt0.format(r.maxPrice);
    byId('subline').textContent = `Financing ${fmt0.format(r.loan)} at ${o.annualRate}% for ${o.termMonths} months ≈ ${fmt0.format(r.payment)}/month (sales tax paid up front; roll it into the loan and the max price drops).`;
    byId('ladder').innerHTML = [o.budget - 100, o.budget, o.budget + 100, o.budget + 200]
      .filter((b) => b > 0)
      .map((b) => {
        const x = carAffordability({ ...o, budget: b });
        return `<tr class="border-b border-navy-50${b === o.budget ? ' bg-accent-50 font-semibold' : ''}">
          <td class="py-2 pr-2">${fmt0.format(b)}</td>
          <td class="py-2 pr-2 text-right tabular-nums">${fmt0.format(x.maxPrice)}</td>
          <td class="py-2 text-right tabular-nums">${fmt0.format(x.loan)}</td></tr>`;
      })
      .join('');
    url.sync();
  }

  url.load();
  onInput('calc-form', recalc);
  byId('calc-form').addEventListener('change', recalc);
  wireActions('#calc');
  recalc();
</script>
