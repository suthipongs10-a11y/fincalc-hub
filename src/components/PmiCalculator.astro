---
/** PMI island: cost per month, months to 78% auto-cancel, extra-payment effect. */
---

<section id="calc" class="rounded-xl border border-navy-100 bg-white shadow-sm" aria-label="PMI calculator">
  <div class="grid gap-0 lg:grid-cols-[minmax(0,22rem)_1fr]">
    <form id="calc-form" class="space-y-4 border-b border-navy-100 p-5 sm:p-6 lg:border-r lg:border-b-0" novalidate>
      <div><label for="price" class="fc-label">Home price (original value)</label>
        <div class="fc-wrap"><span class="fc-prefix">$</span><input id="price" inputmode="decimal" value="400,000" class="fc-input fc-input--pre" /></div></div>
      <div class="grid grid-cols-2 gap-3">
        <div><label for="down" class="fc-label">Down payment</label>
          <div class="fc-wrap"><span class="fc-prefix">$</span><input id="down" inputmode="decimal" value="40,000" class="fc-input fc-input--pre" /></div>
          <p id="ltv-hint" class="mt-1 text-xs text-navy-600"></p></div>
        <div><label for="rate" class="fc-label">Interest rate</label>
          <div class="fc-wrap"><input id="rate" inputmode="decimal" value="6.5" class="fc-input fc-input--suf" /><span class="fc-suffix">%</span></div></div>
        <div><label for="pmi" class="fc-label">PMI rate / yr</label>
          <div class="fc-wrap"><input id="pmi" inputmode="decimal" value="0.5" class="fc-input fc-input--suf" /><span class="fc-suffix">%</span></div></div>
        <div><label for="extra" class="fc-label">Extra payment / mo</label>
          <div class="fc-wrap"><span class="fc-prefix">$</span><input id="extra" inputmode="decimal" value="0" class="fc-input fc-input--pre" /></div></div>
      </div>
      <p class="text-xs text-navy-600">30-year loan assumed. PMI rates run ~0.3–1.5%/yr depending on credit and down payment.</p>
      <p id="calc-error" class="hidden text-sm font-medium text-red-700" role="alert"></p>
      <div class="flex flex-wrap gap-2 pt-1">
        <button type="button" id="share" class="fc-btn">Copy shareable link</button>
        <button type="button" id="print" class="fc-btn fc-btn--ghost">Print results</button>
      </div>
    </form>

    <div class="p-5 sm:p-6">
      <div class="grid gap-3 sm:grid-cols-3">
        <div class="rounded-lg bg-navy-50 p-3"><p class="text-xs font-medium text-navy-600">PMI per month</p>
          <p id="pmi-mo" class="text-lg font-bold text-navy-900" aria-live="polite">—</p></div>
        <div class="rounded-lg bg-navy-50 p-3"><p class="text-xs font-medium text-navy-600">Auto-cancels (78% LTV)</p>
          <p id="pmi-end" class="text-lg font-bold text-navy-900">—</p></div>
        <div class="rounded-lg bg-navy-50 p-3"><p class="text-xs font-medium text-navy-600">Total PMI paid</p>
          <p id="pmi-total" class="text-lg font-bold text-navy-900">—</p></div>
      </div>
      <p id="verdict" class="mt-3 rounded-lg bg-navy-900 p-4 text-sm font-medium text-white">—</p>
      <p class="mt-3 text-xs leading-relaxed text-navy-600">
        Rules modeled: PMI charged while balance &gt; 78% of original value (federal
        auto-termination); you can request cancellation at 80%, or earlier with a new
        appraisal after appreciation. Extra payments pull the date forward — try it.
      </p>
    </div>
  </div>

  <div class="border-t border-navy-100 p-5 sm:p-6">
    <div class="flex flex-wrap items-center justify-between gap-2">
      <h2 class="text-lg font-bold text-navy-900">Amortization schedule (to PMI removal and beyond)</h2>
      <button type="button" id="expand-all" class="text-sm font-medium text-navy-700 underline hover:text-navy-900">Expand all years</button>
    </div>
    <div id="schedule" class="mt-4 space-y-1"></div>
  </div>
</section>

<script>
  import { computeMortgage } from '../lib/mortgage.js';
  import { fmt0, fmt2, num, byId, input, yrMo, renderYearSchedule, urlState, wireActions, onInput } from '../lib/ui.js';

  const url = urlState(['price', 'down', 'rate', 'pmi', 'extra']);

  function recalc() {
    const price = num(input('price'));
    const down = num(input('down'));
    const rate = num(input('rate'));
    const pmiRate = num(input('pmi'));
    const extra = num(input('extra'));
    const err = byId('calc-error');
    let msg = null;
    if (price <= 0) msg = 'Enter a home price above $0.';
    else if (down < 0 || down >= price) msg = 'Down payment must be between $0 and the price.';
    else if (rate < 0 || rate > 25) msg = 'Rate must be between 0% and 25%.';
    if (msg) { err.textContent = msg; err.classList.remove('hidden'); return; }
    err.classList.add('hidden');

    const ltv = ((price - down) / price) * 100;
    byId('ltv-hint').textContent = `${(down / price * 100).toFixed(1)}% down → ${ltv.toFixed(1)}% LTV`;

    const now = new Date();
    const r = computeMortgage({ homePrice: price, downPayment: down, annualRate: rate, termYears: 30, taxRate: 0, insuranceAnnual: 0, pmiRate, hoaMonthly: 0, extraMonthly: extra, startYear: now.getFullYear(), startMonth: now.getMonth() + 2 > 12 ? 1 : now.getMonth() + 2 });

    if (r.monthlyPMI <= 0) {
      byId('pmi-mo').textContent = '$0';
      byId('pmi-end').textContent = '—';
      byId('pmi-total').textContent = '$0';
      byId('verdict').textContent = 'With 20% or more down, conventional loans carry no PMI at all. Nothing to cancel.';
    } else {
      const months = r.rows.filter((x) => x.pmi > 0).length;
      byId('pmi-mo').textContent = fmt2.format(r.monthlyPMI);
      byId('pmi-end').textContent = `${yrMo(months)}`;
      byId('pmi-total').textContent = fmt0.format(r.totalPMI);
      const noExtra = extra > 0 ? computeMortgage({ homePrice: price, downPayment: down, annualRate: rate, termYears: 30, taxRate: 0, insuranceAnnual: 0, pmiRate, hoaMonthly: 0, extraMonthly: 0, startYear: 2026, startMonth: 1 }) : null;
      byId('verdict').textContent = extra > 0 && noExtra
        ? `Your ${fmt0.format(extra)}/month extra removes PMI ${yrMo(noExtra.rows.filter((x) => x.pmi > 0).length - months)} sooner and cuts total PMI from ${fmt0.format(noExtra.totalPMI)} to ${fmt0.format(r.totalPMI)}.`
        : `PMI costs ${fmt2.format(r.monthlyPMI)}/month until the balance reaches ${fmt0.format(price * 0.78)} (78% of value) — ${yrMo(months)} on schedule. Add an extra payment above to pull that forward, or request cancellation at 80% (${fmt0.format(price * 0.8)}).`;
    }
    renderYearSchedule(byId('schedule'), r.rows);
    url.sync();
  }

  url.load();
  onInput('calc-form', recalc);
  wireActions('#schedule');
  recalc();
</script>
