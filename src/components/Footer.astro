---
import { SITE, TOOLS } from '../config';

const year = new Date().getFullYear();
---

<footer class="mt-16 border-t border-navy-800 bg-navy-950 text-navy-200">
  <div class="mx-auto max-w-5xl px-4 py-10 sm:px-6">
    <div class="grid gap-8 sm:grid-cols-3">
      <div>
        <p class="text-base font-bold text-white">{SITE.name}</p>
        <p class="mt-2 text-sm leading-relaxed">
          Free, fast, no-signup financial calculators for mortgages, loans, and
          debt payoff.
        </p>
      </div>
      <nav aria-label="Calculators">
        <p class="text-sm font-semibold tracking-wide text-white uppercase">Calculators</p>
        <ul class="mt-3 space-y-2 text-sm">
          {
            TOOLS.filter((t) => t.core).map((tool) => (
              <li>
                {tool.status === 'coming-soon' ? (
                  <span class="text-navy-400">
                    {tool.name} <span class="text-xs">(coming soon)</span>
                  </span>
                ) : (
                  <a href={`/${tool.slug}/`} class="hover:text-white">
                    {tool.name}
                  </a>
                )}
              </li>
            ))
          }
        </ul>
      </nav>
      <nav aria-label="Company">
        <p class="text-sm font-semibold tracking-wide text-white uppercase">Site</p>
        <ul class="mt-3 space-y-2 text-sm">
          <li><a href="/mortgage-calculator/by-state/" class="hover:text-white">Mortgage by State</a></li>
          <li><a href="/mortgage-payment/" class="hover:text-white">Payments by Amount</a></li>
          <li><a href="/about/" class="hover:text-white">About</a></li>
          <li><a href="/contact/" class="hover:text-white">Contact</a></li>
          <li><a href="/privacy/" class="hover:text-white">Privacy Policy</a></li>
          <li><a href="/terms/" class="hover:text-white">Terms of Use</a></li>
        </ul>
      </nav>
    </div>
    <div class="mt-10 border-t border-navy-800 pt-6 text-xs leading-relaxed text-navy-400">
      <p>
        <strong class="font-semibold text-navy-300">Disclaimer:</strong>
        All calculators and content on this site are for educational purposes
        only and do not constitute financial, legal, or tax advice. Results are
        estimates based on the numbers you enter and may not reflect the actual
        terms available to you. Consult a qualified professional before making
        financial decisions.
      </p>
      <p class="mt-4">&copy; {year} {SITE.name}. All rights reserved.</p>
    </div>
  </div>
</footer>
